        header=True,
    )
    with (OUTPUT / "p1_06_tsmom_macro_bull_metrics.json").open("w") as handle:
        json.dump(output, handle, indent=2, default=str)
    plot_equity(result.equity)
    print(json.dumps(output, indent=2, default=str))


if __name__ == "__main__":
    main()

