            "median_net_pnl": None,
            "mean_r": None,
        }
    return {
        "count": int(len(trades)),
        "net_pnl": float(trades["net_pnl"].sum()),
        "win_rate": float((trades["net_pnl"] > 0).mean()),
        "mean_net_pnl": float(trades["net_pnl"].mean()),
        "median_net_pnl": float(trades["net_pnl"].median()),
        "mean_r": float(trades["expectancy_r"].mean()),
    }


def attach_entry_state(
    trades: pd.DataFrame,
    bars: dict[str, pd.DataFrame],
) -> pd.DataFrame:
    parts = []
    columns = [
        "datetime",
        "execution_macro_bull",
        "execution_plus_di",
        "execution_minus_di",
    ]
    for symbol, group in trades.groupby("symbol"):
        labels = bars[symbol][columns]
        merged = group.merge(
            labels,
            left_on="entry_time",
            right_on="datetime",
            how="left",
            validate="many_to_one",
        )
        if merged["datetime"].isna().any():
            raise ValueError(f"{symbol}: missing macro state at trade entry")
        parts.append(merged.drop(columns=["datetime"]))
    attached = pd.concat(parts, ignore_index=True)
    attached["macro_state"] = attached["execution_macro_bull"].map(
        {True: "bull", False: "bear"}
    ).fillna("unknown")
    direction = pd.Series(
        np.where(
        attached["execution_plus_di"] >= attached["execution_minus_di"],
        "trend_up",
        "trend_down",
        ),
        index=attached.index,
    )
    attached["state_grid"] = direction + "_" + attached["macro_state"]
    attached.loc[
        attached["macro_state"] == "unknown",
        "state_grid",
    ] = "unknown"
    return attached


def macro_gate_trade_attribution(
    result: Result,
    bars: dict[str, pd.DataFrame],
) -> dict[str, object]:
    baseline = pd.read_csv(
        OUTPUT / "p1_04_tsmom_regime_long_trades.csv",
        parse_dates=["signal_time", "entry_time", "exit_time"],
    )
    baseline = attach_entry_state(baseline, bars)
    blocked = baseline[baseline["macro_state"] != "bull"]
    retained = attach_entry_state(result.trades, bars)
    state_rows = {
        state: _trade_distribution(group)
        for state, group in retained.groupby("state_grid")
    }
    macro_exits = result.trades[
        result.trades["exit_reason"] == "MACRO_BEAR_EXIT"
    ]
    blocked_by_year = {
        str(year): _trade_distribution(group)
        for year, group in blocked.groupby(blocked["entry_time"].dt.year)
    }
    return {
        "definition": (
            "Entry-blocked P&L uses completed P1-04 trade segments and is "
            "diagnostic, not a portfolio counterfactual because capital "
            "paths differ after gating."
        ),
        "baseline_trade_count": int(len(baseline)),
        "retained_trade_count": int(len(result.trades)),
        "trade_count_retention_rate": float(
            len(result.trades) / len(baseline)
        ),
        "blocked_at_entry": {
            state: _trade_distribution(group)
            for state, group in blocked.groupby("macro_state")
        },
        "blocked_at_entry_total": _trade_distribution(blocked),
        "blocked_at_entry_by_year": blocked_by_year,
        "macro_bear_exits": _trade_distribution(macro_exits),
        "retained_two_axis_grid": state_rows,
    }


def annual_returns(equity: pd.Series) -> dict[str, float]:
    output = {}
    for year in sorted(equity.index.year.unique()):
        sample = equity[equity.index.year == year]
        output[str(year)] = float(sample.iloc[-1] / sample.iloc[0] - 1)
    return output


def regime_coverage(
    bars: dict[str, pd.DataFrame],
    start: str,
    end: str,
) -> dict[str, float]:
    output = {}
    for symbol, frame in bars.items():
        sample = frame[
            (frame["datetime"] >= pd.Timestamp(start))
            & (frame["datetime"] < pd.Timestamp(end))
        ]
        output[symbol] = float(sample["execution_long"].mean())
    return output


def report_payload(
    bars: dict[str, pd.DataFrame],
    funding: dict[str, pd.DataFrame],
) -> tuple[Result, dict[str, object]]:
    net = run_backtest(
        bars,
        funding,
        include_fees=True,
        include_slippage=True,
        include_funding=True,
    )
    gross = run_backtest(
        bars,
        funding,
        include_fees=False,
        include_slippage=False,
        include_funding=False,
    )
    unfiltered_long = run_backtest(
        bars,
        funding,
        include_fees=True,
        include_slippage=True,
        include_funding=True,
        use_regime=False,
    )
    bounds = boundaries(net.equity)
    by_symbol = {}
    for symbol in SYMBOL_ORDER:
        result = run_backtest(
            bars,
            funding,
            include_fees=True,
            include_slippage=True,
            include_funding=True,
            symbols=(symbol,),
        )
        by_symbol[symbol] = summarize(result)
    payload = {
        "portfolio": summarize(net),
        "gross_zero_cost": summarize(gross),
        "unfiltered_long_only": summarize(unfiltered_long),
        "by_symbol": by_symbol,
        "walk_forward": [
            {
                "window": index + 1,
                **slice_metrics(
                    net.equity,
                    net.trades,
                    bounds[index],
                    bounds[index + 1],
                ),
            }
            for index in range(3)
        ],
        "period_2022": slice_metrics(
            net.equity,
            net.trades,
            pd.Timestamp("2022-01-01"),
            pd.Timestamp("2023-01-01"),
        ),
        "annual_returns": annual_returns(net.equity),
        "macro_gate_bars": macro_gate_bar_diagnostic(bars),
        "macro_gate_trades": macro_gate_trade_attribution(net, bars),
        "eligible_long_fraction_2022": regime_coverage(
            bars,
            "2022-01-01",
            "2023-01-01",
        ),
    }
    main = payload["portfolio"]
    payload["strategy_passed"] = bool(
        main["sharpe"] > 1.0 and abs(main["max_drawdown"]) < 0.50
    )
    payload["sample_grade"] = (
        "CONFIRMATORY"
        if main["trade_count"] >= 500
        else "EXPLORATORY"
        if main["trade_count"] >= 300
        else "INSUFFICIENT"
    )
    baseline = json.loads(
        (OUTPUT / "p1_04_tsmom_regime_long_metrics.json").read_text()
    )
    baseline_equity = pd.read_csv(
        OUTPUT / "p1_04_tsmom_regime_long_equity.csv",
        index_col=0,
        parse_dates=True,
    ).iloc[:, 0]
    payload["p1_04_comparison"] = {
        "net_sharpe_change": float(
            main["sharpe"] - baseline["portfolio"]["sharpe"]
        ),
        "gross_sharpe_change": float(
            payload["gross_zero_cost"]["sharpe"]
            - baseline["gross_zero_cost"]["sharpe"]
        ),
        "max_drawdown_change": float(
            main["max_drawdown"] - baseline["portfolio"]["max_drawdown"]
        ),
        "net_profit_change": float(
            main["net_profit"] - baseline["portfolio"]["net_profit"]
        ),
        "trade_count_change": int(
            main["trade_count"] - baseline["portfolio"]["trade_count"]
        ),
        "fees_change": float(
            main["fees"] - baseline["portfolio"]["fees"]
        ),
        "slippage_change": float(
            main["slippage_cost"]
            - baseline["portfolio"]["slippage_cost"]
        ),
        "funding_change": float(
            main["funding_cost"]
            - baseline["portfolio"]["funding_cost"]
        ),
        "baseline": {
            "portfolio": baseline["portfolio"],
            "gross_zero_cost": baseline["gross_zero_cost"],
            "walk_forward": baseline["walk_forward"],
            "period_2022": baseline["period_2022"],
            "annual_returns": annual_returns(baseline_equity),
        },
    }
    return net, payload


def plot_equity(equity: pd.Series) -> None:
    figure, axis = plt.subplots(figsize=(13, 6))
    axis.plot(equity.index, equity.values, linewidth=1.2)
    axis.axhline(INITIAL_CAPITAL, color="black", linewidth=0.7, alpha=0.5)
    axis.set_title("P1-06 Long TSMOM with Macro Bull Gate")
    axis.set_xlabel("UTC time")
    axis.set_ylabel("Equity (USDT)")
    axis.grid(alpha=0.2)
    figure.tight_layout()
    figure.savefig(OUTPUT / "p1_06_tsmom_macro_bull_equity_curve.png", dpi=160)
    plt.close(figure)


def main() -> None:
    OUTPUT.mkdir(parents=True, exist_ok=True)
    bars, funding = load_pre_holdout()
    result, payload = report_payload(bars, funding)
    output = {
        "experiment": "v6_tsmom_regime_long_v4",
        "holdout_accessed": False,
        "parameters": {
            "lookback_bars": LOOKBACK_BARS,
            "lookback_days": 90,
            "signal": (
                "long when close[t] > close[t-540], ADX trend regime, "
                "and prior completed UTC daily close > daily SMA200"
            ),
            "adx_period": ADX_PERIOD,
            "adx_entry": ADX_ENTRY,
            "adx_exit": ADX_EXIT,
            "regime": "Wilder ADX hysteresis: enter >25, exit <20",
            "macro_ma_days": MACRO_MA_DAYS,
            "macro_gate": (
                "prior completed UTC daily close > its daily SMA200; "
                "warmup unknown blocks long"
            ),
            "direction": "long-only",
            "execution": "signal at t close, execute t+1 open",
            "target_weight_per_symbol": TARGET_WEIGHT,
            "leverage_cap": LEVERAGE_CAP,
            "rebalance_policy": (
                "trade on signal flip; otherwise hold, except proportional "
                "risk-cap deleveraging when open gross exposure exceeds 1x"
            ),
            "leverage_audit": (
                "cap enforced at each 4H open; marked leverage may drift "
                "within the following bar before the next risk-cap check"
            ),
            "fee_each_side": FEE_RATE,
            "slippage_each_side": SLIPPAGE_RATE,
            "funding": "real historical 8H rates, direction-aware",
            "missing_funding_before_first_record": "zero/no settlement record",
        },
        **payload,
    }
    result.trades.to_csv(
        OUTPUT / "p1_06_tsmom_macro_bull_trades.csv",
        index=False,
        date_format="%Y-%m-%d %H:%M:%S",
    )
    result.equity.to_csv(
