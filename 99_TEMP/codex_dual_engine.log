+        f"- L-only annualized log growth: {payload['engines']['L']['acceptance']['metrics']['annualized_log_growth']:.3f}",
+        f"- Correlation vs existing P1-06 daily equity output: {payload['combination']['correlation_vs_existing_p1_06_daily']}",
+        "",
