+            "trend_regime_passive_net_profit": float(p1_04_bm.equity.iloc[-1] - INITIAL_CAPITAL),
+            "excess_profit": float(p1_04.equity.iloc[-1] - p1_04_bm.equity.iloc[-1]),
+        },
+        "p1_06": {
