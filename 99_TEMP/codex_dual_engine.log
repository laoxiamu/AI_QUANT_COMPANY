+    (RESULTS / "20260612_tsmom_dual_engine.md").write_text("\n".join(lines) + "\n")
+
+    checks = [
+        "# REPORT_TSMOM_DUAL_ENGINE",
+        "",
+        "## 验收自检",
+        "",
