+        "run_started_at_utc": utc_now(),
+        "duration_s": args.duration,
+        "proxy_host": args.proxy_host,
+        "proxy_port": args.proxy_port,
+        "tool_inventory": tool_inventory(),
+        "tests": [],
+    }
+
+    payload["tests"].append(
+        test_websocket_client(
+            "websocket_client_http_ws",
+            WS_PATH_URL,
+            args.duration,
+            args.proxy_host,
+            args.proxy_port,
+            "http",
+        )
