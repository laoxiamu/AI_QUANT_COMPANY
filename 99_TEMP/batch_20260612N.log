+            )
+            for line in proc.stdout.splitlines():
+                if line.startswith("Protocols:"):
+                    curl_protocols = line.split(":", 1)[1].strip().split()
+                    break
+        except Exception:
+            curl_protocols = []
+    return {
+        "curl": {
+            "path": curl_path,
+            "supports_ws": "ws" in curl_protocols or "wss" in curl_protocols,
