+    matured = summary[summary["matured_30d_window"]]
+    available = int(matured["archive_window_available"].sum())
+    print(
+        f"matured={len(matured)} available={available} rate={pct(available, len(matured))}",
+        flush=True,
+    )
+
+
+if __name__ == "__main__":
+    main()

