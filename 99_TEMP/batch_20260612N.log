+    frame["onboard_day"] = frame["onboard_date"].map(parse_day)
+    frame["delist_day"] = frame["delist_date"].map(parse_day)
+    if frame["onboard_day"].isna().any():
+        raise ValueError("UNIVERSE_PIT has empty onboard_date values")
+    return frame
+
