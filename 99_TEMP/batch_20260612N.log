+
+    def add_to_position(
+        position: Position,
+        raw_price: float,
+        add_notional: float,
+    ) -> None:
+        nonlocal cash
+        if add_notional <= 0:
+            return
+        entry_price = price_with_slippage(raw_price, position.direction, True)
