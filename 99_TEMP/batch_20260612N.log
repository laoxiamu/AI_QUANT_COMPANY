+                "ending_equity": read_existing_terminal(OUTPUT / "p1_04_tsmom_regime_long_equity.csv"),
+            },
+            "P1-06": {
+                "path": "06_RESEARCH/CODE/output/p1_06_tsmom_macro_bull_equity.csv",
