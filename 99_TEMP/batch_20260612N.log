+    (CODEX_TASKS / "REPORT_B2.md").write_text("\n".join(report_lines) + "\n")
+
+
+def main() -> None:
+    bars, funding, audit = read_frozen_inputs()
+    prepared = add_features(bars)
+    results: dict[str, Result] = {}
+    payload: dict[str, object] = {
