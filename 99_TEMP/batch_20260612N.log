+                "strategy_trades": record["strategy"]["trade_count"],
+                "benchmark_trades": record["benchmark"]["trade_count"],
+                "strategy_funding_cost": record["strategy"]["funding_cost"],
+                "benchmark_funding_cost": record["benchmark"]["funding_cost"],
+            }
