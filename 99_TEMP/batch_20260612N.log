+    except Exception as exc:  # noqa: BLE001 - diagnostic must preserve failure class
+        result["error"] = f"{type(exc).__name__}: {exc}"
+    finally:
+        result["elapsed_s"] = round(time.monotonic() - start, 3)
+        result["ended_at_utc"] = utc_now()
+    return result
