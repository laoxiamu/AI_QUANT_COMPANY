+    print(f"Wrote {NEW_HASH_PATH.relative_to(PROJECT_ROOT)}")
+    print(f"Wrote {REPORT_PATH.relative_to(PROJECT_ROOT)}")
+
+
+if __name__ == "__main__":
+    main()

