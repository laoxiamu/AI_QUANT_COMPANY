+                    FileSpec(mark_path, "mark", "4h", 4, FUTURES_DIR / "BTCUSDT_MARK_4H.csv"),
+                    FileSpec(funding_path, "funding", "8h", 8, FUTURES_DIR / "BTCUSDT_FUNDING_8H.csv"),
+                ]
