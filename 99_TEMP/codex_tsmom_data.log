+            funding_frames = collected[funding_key] + [funding_api_frames[symbol]]
+            funding = normalize_funding(funding_frames)
+            mark_path = FUTURES_DIR / f"{symbol}_MARK_4H.csv"
+            funding_path = FUTURES_DIR / f"{symbol}_FUNDING_8H.csv"
